# C1 infra-base 环境变量示例 — 复制为 .env 后填值
# .env 已在 .gitignore 中(不会入 git)

# ===== 数据库 =====
# 本地跑后端用这个(对应 docker compose 的 postgres)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/documentcheck

# ===== LLM 适配层 =====
# dashscope(推荐,国内可达性好) | openai
LLM_PROVIDER=dashscope
# dashscope API Key(在 https://dashscope.console.aliyun.com/ 创建);openai 时填 OpenAI key
LLM_API_KEY=
# 默认 qwen-plus(dashscope);openai 时改 gpt-4o-mini 等
LLM_MODEL=qwen-plus
# 可选:自定义 base_url(默认按 provider 取,见 app/services/llm/openai_compat.py)
# LLM_BASE_URL=
LLM_TIMEOUT_S=30

# ===== 数据生命周期(C1 强制 dry-run;真删随 C4 开放) =====
LIFECYCLE_DRY_RUN=true
LIFECYCLE_INTERVAL_S=3600
LIFECYCLE_AGE_DAYS=30

# ===== JWT(本 change 不使用,C2 auth 才真正落地) =====
SECRET_KEY=change-this-in-production
