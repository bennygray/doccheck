DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/documentcheck
SECRET_KEY=change-this-in-production
DEBUG=true
CORS_ORIGINS=["http://localhost:5173"]
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
# LLM 调用全局 cap(秒);慢模型(ark-code-latest 类)实测 35~132s,默认 300 够用;
# 若部署用快模型可手工压低:LLM_CALL_TIMEOUT=60
# LLM_CALL_TIMEOUT=300
