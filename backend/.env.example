DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/documentcheck
SECRET_KEY=change-this-in-production
DEBUG=true
CORS_ORIGINS=["http://localhost:5173"]
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# LLM timeout 两个独立字段,实际生效 = min(per_call, cap):
#   LLM_TIMEOUT_S       — per-call 实际超时;每次 LLM 调用的 asyncio.wait_for(timeout=...)
#   LLM_CALL_TIMEOUT    — 全局 cap;admin-llm-config 配大值时的天花板
# 两者代码默认都 300 秒,支撑慢模型(ark-code-latest 类 role_classifier 实测 35~132s,
# price_rule_detector 实测 ~113s)。改 cap 不会反向把 per-call 拉高。
# 想让某次部署快失败 → 设 LLM_TIMEOUT_S=60(per-call 压低),不要改 cap。
# LLM_TIMEOUT_S=300
# LLM_CALL_TIMEOUT=300
